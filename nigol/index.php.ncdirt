						      		function filterSQL($string)
								    {
								    	$string = strtolower($string);
										$string = str_replace('update', '', $string);
										$string = str_replace('delete', '', $string);
										$string = str_replace('insert', '', $string);

										return $string;
								    }
							        $user 	= $_POST['user'];
